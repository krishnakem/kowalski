{
  "name": "vite_react_shadcn_ts",
  "productName": "Kowalski",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postinstall": "playwright install chromium",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:compile": "node scripts/build-electron.mjs",
    "electron": "npm run electron:compile && wait-on tcp:8080 && electron .",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"cross-env VITE_DEV_SERVER_URL=http://localhost:8080 npm run electron\"",
    "electron:build": "npm run build && npm run electron:compile && electron-builder",
    "stage:browsers": "node scripts/stage-playwright-browsers.mjs",
    "generate:icns": "node scripts/generate-icns.mjs",
    "dist:dir": "npm run build && npm run electron:compile && npm run stage:browsers && npm run generate:icns && electron-builder --mac --dir",
    "setup:browser": "npx tsx scripts/setup-kowalski-browser.ts",
    "setup:icons": "npx tsx scripts/standardize-icon.ts && npm run generate:icns",
    "setup": "npm run setup:icons && npm run setup:browser",
    "test:digest": "npx tsx scripts/test-digest.ts",
    "test:extract": "npx tsx scripts/test-extract.ts"
  },
  "appId": "com.krishnakemisetti.kowalski",
  "copyright": "Copyright © 2026 Krishna Kemisetti",
  "build": {
    "appId": "dev.jovy.kowalski",
    "productName": "Kowalski",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon*.png",
      "build/icon*.icns",
      "build/icon*.ico",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/tsconfig*.json",
      "!src/**",
      "!scripts/**",
      "!debug-screenshots/**",
      "!Kowalski.iconset/**",
      "!build-resources/**",
      "!electron-main.*",
      "!minimal-test.*",
      "!bun.lockb",
      "!node_modules/playwright-core/.local-browsers/**",
      "!node_modules/playwright/.local-browsers/**"
    ],
    "extraResources": [
      {
        "from": "build-resources/playwright-browsers",
        "to": "playwright-browsers",
        "filter": [
          "**/*"
        ]
      }
    ],
    "buildDependenciesFromSource": true,
    "asar": false,
    "afterPack": "scripts/sign-app.mjs",
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.83.0",
    "@types/uuid": "^10.0.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.26",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "playwright": "^1.57.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.61.1",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "vaul": "^0.9.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@hunlongyu/electron-icon-builder": "^0.1.5",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.2",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jimp": "^1.6.0",
    "lovable-tagger": "^1.1.13",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.4.19",
    "wait-on": "^9.0.3"
  }
}
